APP_NAME=OpenFileShield
APP_HOST=0.0.0.0
APP_PORT=8080
APP_ROLE=all
PUBLIC_PORT=8080
ADMIN_PORT=8081
ADMIN_HOST=127.0.0.1
ADMIN_BASE_URL=http://127.0.0.1:8081
PUBLIC_DOMAIN=upload.example.com
ADMIN_DOMAIN=admin.example.com
ACME_EMAIL=admin@example.com
DATABASE_URL=sqlite:///./data/openfileshield.db
UPLOAD_DIR=./data/uploads
QUARANTINE_DIR=./data/quarantine
ALLOWED_FILE_TYPES=*
SCAN_REQUIRED=true
CLAMD_HOST=clamav
CLAMD_PORT=3310
UPLOAD_RATE_LIMIT_PER_MINUTE=60
UPLOAD_RATE_BURST_PER_10_SECONDS=12
REQUEST_TIMEOUT_SECONDS=120
DEDUPE_MODE=reference
ASYNC_SCAN_ENABLED=true
ASYNC_SCAN_WORKERS=2
TREND_DAYS_DEFAULT=14
TRUST_X_FORWARDED_FOR=true
ADMIN_TOKEN=change-this-token
ADMIN_LOCAL_ONLY=true
MAX_ADMIN_RESULTS=500
DEFAULT_ADMIN_RESULTS=100
ENABLE_CSV_EXPORT=true
ADMIN_AUTO_REFRESH_SECONDS=15
SERVICE_NOTICE=Public upload with malware scanning and audit logging
